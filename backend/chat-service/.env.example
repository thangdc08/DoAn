PORT=8686

# MongoDB
# Local without auth:
URI_MONGODB_CHAT=mongodb://localhost:27017/chat
# If your Mongo requires auth, use:
# URI_MONGODB_CHAT=mongodb://root:root@localhost:27017/chat?authSource=admin

# Kafka
KAFKA_SERVER=localhost:9094
# Set false to run chat-service without Kafka in local dev
ENABLE_KAFKA=false

# Eureka / gateway / auth
ENABLE_EUREKA=false
SECRET_KEY=change_me
TRUST_GATEWAY_JWT=true
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_SERVICE_PATH=/eureka/apps/
HOST_NAME=localhost
IP_ADDRESS=127.0.0.1
API_BASE_URL=http://localhost:8080
