{
	"info": {
		"_postman_id": "onboarding-test-id",
		"name": "Partner Onboarding Test",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Step 1: Register Owner",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"owner_token\", jsonData.accessToken);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"fullName\": \"Chủ sân Test\",\n    \"email\": \"owner_test@example.com\",\n    \"phone\": \"0988777666\",\n    \"level\": \"ADVANCED\",\n    \"password\": \"12345678\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/identity/api/v1/auth/register-owner",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"identity",
						"api",
						"v1",
						"auth",
						"register-owner"
					]
				}
			},
			"response": []
		},
		{
			"name": "Step 2: Onboard Venue",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{owner_token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"venueName\": \"Sân Cầu Lông Pro Max\",\n    \"address\": \"123 Đường ABC, Quận 1\",\n    \"city\": \"Hồ Chí Minh\",\n    \"courtCount\": 5,\n    \"utilities\": [\"Wifi\", \"Bãi xe\", \"Căng tin\"],\n    \"latitude\": 10.762622,\n    \"longitude\": 106.660172,\n    \"openTime\": \"05:00:00\",\n    \"closeTime\": \"22:00:00\",\n    \"pricing\": [\n        {\n            \"from\": \"05:00:00\",\n            \"to\": \"17:00:00\",\n            \"price\": 80000\n        },\n        {\n            \"from\": \"17:00:00\",\n            \"to\": \"22:00:00\",\n            \"price\": 120000\n        }\n    ]\n}"
				},
				"url": {
					"raw": "http://localhost:8080/venues/api/v1/venues/onboard",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"venues",
						"api",
						"v1",
						"venues",
						"onboard"
					]
				}
			},
			"response": []
		}
	]
}
