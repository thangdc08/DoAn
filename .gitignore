# ============================================================
# JAVA / SPRING BOOT
# ============================================================

# Build output
**/target/
**/build/
**/*.class
**/*.jar
**/*.war
**/*.ear

# Maven wrapper cache
**/.mvn/wrapper/maven-wrapper.jar

# Spring Boot devtools
.spring-boot-devtools.properties

# ============================================================
# NODE / REACT / VITE
# ============================================================

# Dependencies
**/node_modules/

# Build output
**/dist/
**/dist-ssr/
**/.next/
**/out/

# Cache
**/.cache/
**/.parcel-cache/
**/.vite/

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/*.log

# TypeScript
**/*.tsbuildinfo

# ESLint cache
**/.eslintcache

# ============================================================
# ENVIRONMENT & SECRETS
# ============================================================

.env
.env.*
!.env.example        # giữ lại file mẫu

# ============================================================
# DOCKER / INFRASTRUCTURE
# ============================================================

# Terraform
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/*.tfvars
!*.tfvars.example

# Docker override (local only)
docker-compose.override.yml

# ============================================================
# IDE & EDITORS
# ============================================================

# IntelliJ IDEA
**/.idea/
**/*.iml
**/*.ipr
**/*.iws

# Eclipse
**/.project
**/.classpath
**/.settings/
**/.factorypath
**/.springBeans

# VS Code (giữ lại shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ============================================================
# OS
# ============================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# PROJECT SPECIFIC
# ============================================================

# Tài liệu nội bộ (không push lên repo)
TaiLieu/

# Agent config (local tooling)
.agent/